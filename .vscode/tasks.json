{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "fe_hotel: Build & Deploy",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-Command", "chcp 65001 | Out-Null; & '${workspaceFolder}\\fe_hotel\\run.ps1'"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "fe_hotel 빌드 후 Tomcat에 배포"
    },
    {
      "label": "fe_hotel: Build Only",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolic", "Bypass", "-Command", "& '${workspaceFolder}\\apache-maven-3.9.6\\bin\\mvn.cmd' clean package -DskipTests"],
      "options": {
        "cwd": "${workspaceFolder}\\fe_hotel"
      },
      "group": "build",
      "problemMatcher": [],
      "detail": "fe_hotel Maven 빌드만 실행"
    },
    {
      "label": "fe_hotel: Maven Build",
      "type": "shell",
      "command": "${workspaceFolder}\\apache-maven-3.9.6\\bin\\mvn.cmd",
      "args": ["clean", "package", "-DskipTests"],
      "options": {
        "cwd": "${workspaceFolder}\\fe_hotel"
      },
      "group": "build",
      "problemMatcher": [],
      "detail": "fe_hotel Maven build"
    },
    {
      "label": "Tomcat: Start",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}\\tomcat-start-all.ps1"],
      "isBackground": true,
      "problemMatcher": [],
      "detail": "fe_hotel 빌드 → Tomcat 시작 → Watch 자동 실행"
    },
    {
      "label": "Tomcat: Stop",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "set CATALINA_HOME=${workspaceFolder}\\tomcat&& call ${workspaceFolder}\\tomcat\\bin\\shutdown.bat 2>nul & exit /b 0"],
      "problemMatcher": [],
      "detail": "Tomcat 서버 중지"
    },
    {
      "label": "fe_hotel: Watch & Auto Deploy",
      "type": "shell",
      "command": "powershell",
      "args": ["-ExecutionPolicy", "Bypass", "-Command", "chcp 65001 | Out-Null; & '${workspaceFolder}\\fe_hotel\\watch.ps1'"],
      "isBackground": true,
      "problemMatcher": [],
      "detail": "fe_hotel 파일 변경 감시 - JSP/CSS/JS는 즉시 복사, Java/XML은 재빌드 후 재배포"
    }
  ]
}
